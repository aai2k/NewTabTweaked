{
  "manifest_version": 3,
  "name": "Clean New Tab",
  "version": "1.0",
  "description": "Default Chrome new tab without the doodle, with a weather widget.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["topSites"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://www.google.com/*"
  ]
}
