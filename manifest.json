{
  "manifest_version": 3,
  "name": "New Tab Tweaked",
  "version": "1.1",
  "description": "Default Chrome new tab without the doodle, with an interactive search bar, weather widget, and custom shortcuts.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["topSites", "tabs"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://suggestqueries.google.com/*",
    "https://www.google.com/*"
  ]
}
